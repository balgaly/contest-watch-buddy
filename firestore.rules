rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email == 'balgaly@gmail.com';
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50;
      allow update: if isAuthenticated()
        && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Contests (public read - needed for login screen)
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAdmin();

      match /contestants/{contestantId} {
        allow read: if true;
        allow write: if isAdmin();

        match /scores/{scoreUserId} {
          allow read: if isAuthenticated();
          allow create, update: if isAuthenticated()
            && request.auth.uid == scoreUserId
            && request.resource.data.voterName is string;
          allow delete: if isAuthenticated()
            && (request.auth.uid == scoreUserId || isAdmin());
        }
      }
    }

    // Collection group query for scores (single listener optimization)
    match /{path=**}/scores/{scoreUserId} {
      allow read: if isAuthenticated();
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.code is string
        && request.resource.data.code.size() == 6
        && request.resource.data.contestId is string
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.auth.uid == memberId;
        allow update: if isAuthenticated()
          && (request.auth.uid == memberId || isAdmin());
        allow delete: if isAuthenticated()
          && (request.auth.uid == memberId || isAdmin());
      }

      // Emoji reactions (ephemeral, 30s window)
      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.emoji is string
          && request.resource.data.emoji.size() <= 4
          && request.resource.data.timestamp is timestamp;
        // No update/delete — reactions are fire-and-forget
      }

      // Presence tracking (LIVE badge)
      match /presence/{userId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.lastActive is timestamp;
      }
    }
  }
}
